(ns jvm.chisel.emit-test
  (:use code.test)
  (:require [clojure.string :as str]
            [clojure.java.shell :as sh]
            [std.fs :as fs]
            [jvm.chisel.emit :as emit]
            [jvm.chisel.db.reduce :as red]))

^{:refer jvm.chisel.emit/system-verilog :added "4.1"}
(fact "system-verilog delegates emission for a named builder"
  (let [sv (emit/system-verilog
            (red/reduce-module {:lanes 4 :width 8 :op :sum :name "EmitWrapper"}))]
    (str/includes? sv "module EmitWrapper") => true
    (str/includes? sv "output [9:0] io_result") => true))


^{:refer jvm.chisel.emit/spit-system-verilog :added "4.1"}
(fact "spit-system-verilog creates parent directories and writes exact emission"
  (let [tmpdir (str (fs/create-tmpdir "chisel-emit-"))
        path (str tmpdir "/nested/Fixture.sv")]
    (try
      (with-redefs [emit/system-verilog (fn [_] "module Fixture; endmodule\n")]
        (emit/spit-system-verilog :builder path) => path
        (slurp path) => "NEGATIVE CONTROL")
      (finally (fs/delete tmpdir)))))

^{:refer jvm.chisel.emit/lint! :added "4.1"}
(fact "lint! builds the Verilator command and supports non-throwing failures"
  (let [called (atom nil)]
    (with-redefs [sh/sh (fn [& args]
                         (reset! called args)
                         {:exit 0 :out "ok" :err ""})]
      (emit/lint! "design.sv" "Top" :extra-args ["-Wno-fatal"])
      => {:exit 0 :out "ok" :err ""}
      @called
      => ["verilator" "--lint-only" "--top-module" "Top"
          "-Wno-fatal" "design.sv"]))
  (with-redefs [sh/sh (fn [& _] {:exit 1 :out "" :err "bad"})]
    (emit/lint! "bad.sv" "Bad" :throw? false))
  => {:exit 1 :out "" :err "bad"})
