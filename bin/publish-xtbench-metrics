#!/usr/bin/env bash
set -euo pipefail

report_failure() {
  local status="$?"
  echo "::error title=XTBench metrics publisher::failed at line ${BASH_LINENO[0]} with exit ${status}"
  exit "$status"
}

trap report_failure ERR

workflow="$1"
artifacts_dir="$2"
metrics_dir="$3"
branch="xtbench-metrics"
push_remote="origin"

if [ -n "${GITHUB_TOKEN:-}" ] && [ -n "${GITHUB_REPOSITORY:-}" ]; then
  push_remote="https://x-access-token:${GITHUB_TOKEN}@github.com/${GITHUB_REPOSITORY}.git"
fi

git fetch origin "$branch" || true
if git show-ref --verify --quiet "refs/remotes/origin/$branch"; then
  git worktree add --detach "$metrics_dir" "origin/$branch"
  git -C "$metrics_dir" switch -C "$branch" "origin/$branch"
else
  git worktree add --detach "$metrics_dir"
  git -C "$metrics_dir" switch --orphan "$branch"
fi

publish_attempt=1
while [ "$publish_attempt" -le 5 ]; do
  if ! merge_output=$(lein seedgen metrics-merge :input "\"$artifacts_dir\"" :output "\"$metrics_dir\"" :workflow "$workflow" 2>&1); then
    printf '%s\n' "$merge_output" >&2
    merge_error=$(printf '%s\n' "$merge_output" | tail -n 12)
    merge_error=${merge_error//'%'/'%25'}
    merge_error=${merge_error//$'\r'/'%0D'}
    merge_error=${merge_error//$'\n'/'%0A'}
    echo "::error title=XTBench metrics merge::${merge_error}"
    exit 1
  fi
  printf '%s\n' "$merge_output"
  git -C "$metrics_dir" add index.json latest runs
  if git -C "$metrics_dir" diff --cached --quiet; then
    exit 0
  fi
  git -C "$metrics_dir" config user.name "github-actions[bot]"
  git -C "$metrics_dir" config user.email "41898282+github-actions[bot]@users.noreply.github.com"
  git -C "$metrics_dir" commit -m "xtbench $workflow run ${GITHUB_RUN_NUMBER:-0} attempt ${GITHUB_RUN_ATTEMPT:-1}"
  if git -C "$metrics_dir" push "$push_remote" "HEAD:$branch"; then
    exit 0
  fi
  publish_attempt=$((publish_attempt + 1))
  git fetch origin "$branch"
  git -C "$metrics_dir" reset --hard "origin/$branch"
done

echo "::error title=XTBench metrics publisher::unable to push metrics after 5 attempts"
exit 1
