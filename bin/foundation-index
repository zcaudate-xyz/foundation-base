#!/bin/bash
#
# Foundation Library Index Manager
# 
# This script manages the Clojure symbol index for the foundation library.
# It provides commands to index, search, and query the symbol database.
#
# Usage: ./bin/foundation-index [command] [options]
#

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
DB_PATH="${PROJECT_ROOT}/.clojure-mcp/symbol-index.db"

# Helper functions
log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_debug() {
    echo -e "${BLUE}[DEBUG]${NC} $1"
}

# Check if lein is available
check_lein() {
    if ! command -v lein &> /dev/null; then
        log_error "Leiningen not found. Please install lein first."
        exit 1
    fi
}

# Get classpath (cached for performance)
get_classpath() {
    local cp_file="${PROJECT_ROOT}/.cpcache/classpath"
    if [[ -f "$cp_file" ]] && [[ "$cp_file" -nt "${PROJECT_ROOT}/project.clj" ]]; then
        cat "$cp_file"
    else
        mkdir -p "${PROJECT_ROOT}/.cpcache"
        cd "$PROJECT_ROOT"
        lein classpath > "$cp_file" 2>/dev/null
        cat "$cp_file"
    fi
}

# Run Clojure code
run_clojure() {
    local code="$1"
    cd "$PROJECT_ROOT"
    java -cp "$(get_classpath)" clojure.main -e "$code"
}

# Initialize the database
cmd_init() {
    log_info "Initializing foundation index database..."
    run_clojure "(require '[mcp-clj.foundation-index.core :as fi]) (fi/init!) (println \"Database initialized at:\") (println (:path (fi/stats)))"
}

# Index the foundation library
cmd_index() {
    local force="${1:-false}"
    log_info "Indexing foundation library..."
    log_info "This may take 30-60 seconds..."
    
    local force_flag=""
    if [[ "$force" == "--force" ]] || [[ "$force" == "-f" ]]; then
        force_flag="true"
        log_warn "Force re-indexing all files"
    else
        force_flag="false"
    fi
    
    run_clojure "
(require '[mcp-clj.foundation-index.core :as fi])
(let [start (System/currentTimeMillis)
      result (fi/index-directory 
               \"src\"
               :exclude [\".git\" \"target\" \"test\"]
               :force? ${force_flag}
               :progress-fn (fn [idx total status file]
                             (when (= 0 (mod idx 100))
                               (println (format \"Progress: %d/%d files (%s)\" idx total status)))))]
  (let [elapsed (/ (- (System/currentTimeMillis) start) 1000.0)]
    (println (format \"\\n✓ Indexed in %.1f seconds\" elapsed))
    (println (format \"  Files scanned: %d\" (:files-scanned result)))
    (println (format \"  New symbols: %d\" (:new result)))
    (println (format \"  Updated: %d\" (:updated result)))
    (println (format \"  Unchanged: %d\" (:unchanged result)))))
"
}

# Show index statistics
cmd_stats() {
    log_info "Index statistics:"
    run_clojure "
(require '[mcp-clj.foundation-index.core :as fi])
(let [s (fi/stats)]
  (println (format \"Database: %s\" \"${DB_PATH}\"))
  (println (format \"Files indexed:   %d\" (:files s)))
  (println (format \"Total symbols:   %d\" (:symbols s)))
  (println (format \"Namespaces:      %d\" (:namespaces s)))
  (println \"\\nBy kind:\")
  (doseq [[kind count] (sort-by val > (:by-kind s))]
    (println (format \"  %-12s: %d\" (name kind) count))))
"
}

# Search for symbols
cmd_search() {
    local query="$1"
    local kind="${2:-}"
    local namespace="${3:-}"
    
    if [[ -z "$query" ]]; then
        log_error "Search query required"
        echo "Usage: $0 search <query> [kind] [namespace]"
        exit 1
    fi
    
    log_info "Searching for: '$query'"
    
    local kind_filter=""
    local ns_filter=""
    
    if [[ -n "$kind" ]]; then
        kind_filter="\"${kind}\""
        log_info "Filtering by kind: $kind"
    else
        kind_filter="nil"
    fi
    
    if [[ -n "$namespace" ]]; then
        ns_filter="\"${namespace}\""
        log_info "Filtering by namespace: $namespace"
    else
        ns_filter="nil"
    fi
    
    run_clojure "
(require '[mcp-clj.foundation-index.core :as fi])
(let [results (fi/search \"${query}\" :kind ${kind_filter} :namespace ${ns_filter} :limit 50)]
  (println (format \"Found %d symbols:\\n\" (count results)))
  (doseq [sym results]
    (println (format \"  %-60s (%s)\" 
                    (:qualified-name sym)
                    (:kind sym)))
    (when (:arglists sym)
      (println (format \"    Args: %s\" (pr-str (:arglists sym)))))
    (when (:docstring sym)
      (let [doc (if (> (count (:docstring sym)) 80)
                  (str (subs (:docstring sym) 0 77) \"...\")
                  (:docstring sym))]
        (println (format \"    Doc: %s\" doc))))
    (println)))
"
}

# Get symbol details
cmd_symbol() {
    local qualified_name="$1"
    
    if [[ -z "$qualified_name" ]]; then
        log_error "Qualified name required"
        echo "Usage: $0 symbol <qualified-name>"
        echo "Example: $0 symbol std.lang/emit"
        exit 1
    fi
    
    log_info "Getting symbol: $qualified_name"
    
    run_clojure "
(require '[mcp-clj.foundation-index.core :as fi])
(if-let [info (fi/describe-symbol \"${qualified_name}\")]
  (let [sym (:symbol info)]
    (println (format \"Symbol: %s\" (:qualified-name sym)))
    (println (format \"Kind:   %s\" (:kind sym)))
    (println (format \"NS:     %s\" (:namespace sym)))
    (println (format \"File:   %s:%s\" (:file sym) (:line sym)))
    (when (:private sym) (println \"Private: true\"))
    (when (:deprecated sym) (println \"Deprecated: true\"))
    (when (:arglists sym)
      (println (format \"\\nArgs: %s\" (pr-str (:arglists sym)))))
    (when (:docstring sym)
      (println \"\\nDocstring:\")
      (println (:docstring sym)))
    (when (seq (:same-file info))
      (println \"\\nOther symbols in same file:\")
      (doseq [other (take 10 (:same-file info))]
        (println (format \"  - %s (%s)\" (:name other) (:kind other))))))
  (do
    (println (format \"Symbol not found: %s\" \"${qualified_name}\"))
    (println \"\\nDid you mean:\")
    (let [suggestions (take 5 (fi/search \"${qualified_name}\"))]
      (doseq [s suggestions]
        (println (format \"  - %s\" (:qualified-name s)))))))
"
}

# List all namespaces
cmd_namespaces() {
    log_info "Listing all indexed namespaces..."
    
    run_clojure "
(require '[mcp-clj.foundation-index.core :as fi])
(let [nss (fi/list-namespaces)]
  (println (format \"Total: %d namespaces\\n\" (count nss)))
  (doseq [ns (sort-by :name nss)]
    (println (:name ns))))
"
}

# Show file outline
cmd_outline() {
    local file_path="$1"
    
    if [[ -z "$file_path" ]]; then
        log_error "File path required"
        echo "Usage: $0 outline <file-path>"
        echo "Example: $0 outline src/std/lang.clj"
        exit 1
    fi
    
    log_info "Outline for: $file_path"
    
    run_clojure "
(require '[mcp-clj.foundation-index.core :as fi])
(let [symbols (fi/get-file-symbols \"${file_path}\")]
  (println (format \"File: %s\" \"${file_path}\"))
  (println (format \"Symbols: %d\\n\" (count symbols)))
  (doseq [sym symbols]
    (println (format \"  [%s] %s (line %s)\" 
                    (:kind sym)
                    (:name sym)
                    (:line sym)))
    (when (:arglists sym)
      (println (format \"        %s\" (pr-str (:arglists sym)))))))
"
}

# Clear the index
cmd_clear() {
    log_warn "This will delete the entire index!"
    read -p "Are you sure? (yes/no): " confirm
    if [[ "$confirm" == "yes" ]]; then
        log_info "Clearing index..."
        run_clojure "(require '[mcp-clj.foundation-index.core :as fi]) (fi/clear!) (println \"Index cleared\")"
    else
        log_info "Cancelled"
    fi
}

# Show help
cmd_help() {
    cat << 'EOF'
Foundation Library Index Manager

Usage: foundation-index [command] [options]

Commands:
  init                    Initialize the index database
  index [--force]         Index the foundation library (use --force to re-index)
  stats                   Show index statistics
  search <query> [kind] [namespace]
                          Search for symbols
  symbol <qualified-name> Get detailed info about a symbol
  namespaces              List all indexed namespaces
  outline <file-path>     Show symbols in a file
  clear                   Clear the entire index
  help                    Show this help

Examples:
  # Index the foundation library
  ./bin/foundation-index index

  # Search for 'emit' functions
  ./bin/foundation-index search emit function

  # Search in std.lang namespace
  ./bin/foundation-index search emit "" std.lang

  # Get symbol details
  ./bin/foundation-index symbol std.lang/emit

  # Show file outline
  ./bin/foundation-index outline src/std/lang.clj

  # Show statistics
  ./bin/foundation-index stats

Database location: .clojure-mcp/symbol-index.db
EOF
}

# Main command dispatcher
main() {
    check_lein
    
    local cmd="${1:-help}"
    shift || true
    
    case "$cmd" in
        init)
            cmd_init "$@"
            ;;
        index)
            cmd_index "$@"
            ;;
        stats)
            cmd_stats
            ;;
        search)
            cmd_search "$@"
            ;;
        symbol)
            cmd_symbol "$@"
            ;;
        namespaces|ns)
            cmd_namespaces
            ;;
        outline)
            cmd_outline "$@"
            ;;
        clear)
            cmd_clear
            ;;
        help|--help|-h)
            cmd_help
            ;;
        *)
            log_error "Unknown command: $cmd"
            cmd_help
            exit 1
            ;;
    esac
}

# Run main
main "$@"
