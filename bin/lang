#!/bin/bash
#
# XTalk Language Management CLI
#
# This script provides a command-line interface for managing XTalk language
# specifications, model inventories, test coverage, and runtime configurations.
#
# Usage: ./bin/lang [command] [options]
#
# Commands:
#   inventory       Show model and test inventory across XTalk languages
#   audit           Audit XTalk specifications and runtime support
#   scaffold        Generate language model or test scaffolding
#   help            Show this help message
#
# Examples:
#   ./bin/lang inventory
#   ./bin/lang audit --format json
#   ./bin/lang scaffold --lang python --type model
#

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Helper functions
log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_debug() {
    echo -e "${BLUE}[DEBUG]${NC} $1"
}

header() {
    echo -e "${CYAN}$1${NC}"
}

# Get classpath (cached for performance)
get_classpath() {
    local cp_file="${PROJECT_ROOT}/.cpcache/classpath"
    if [[ -f "$cp_file" ]] && [[ "$cp_file" -nt "${PROJECT_ROOT}/project.clj" ]]; then
        cat "$cp_file"
    else
        mkdir -p "${PROJECT_ROOT}/.cpcache"
        (
            cd "$PROJECT_ROOT"
            lein classpath > "$cp_file"
        )
        cat "$cp_file"
    fi
}

# Run Clojure code
run_clojure() {
    local code="$1"
    (
        cd "$PROJECT_ROOT"
        java -cp "$(get_classpath)" clojure.main -e "$code"
    )
}

# Check if lein is available
check_lein() {
    if ! command -v lein &> /dev/null; then
        log_error "Leiningen not found. Please install lein first."
        exit 1
    fi
}

# Show inventory of XTalk models and tests
cmd_inventory() {
    log_info "Fetching XTalk model and test inventory..."
    run_clojure "
(require '[std.lang.manage :as m]
         '[clojure.pprint :as pp])
(println \"\\n=== XTalk Model Inventory ===\")
(println)
(pp/pprint (m/xtalk-model-inventory))
(println)
(println \"=== XTalk Test Inventory ===\")
(println)
(pp/pprint (m/xtalk-test-inventory))
(println)
(println \"=== Runtime Language Configuration ===\")
(println)
(let [inventory (m/xtalk-model-inventory)]
  (println (str \"Total supported languages: \" (count inventory)))
  (println (str \"Languages: \" (clojure.string/join \", \" (map name (keys inventory))))))
"
}

# Show audit information
cmd_audit() {
    log_info "Auditing XTalk specifications and coverage..."
    run_clojure "
(require '[std.lang.manage.xtalk-audit :as audit]
         '[clojure.pprint :as pp])
(println \"\\n=== Installed Languages ===\")
(println)
(let [installed (audit/installed-languages)]
  (println (str \"Found \" (count installed) \" installed languages:\"))
  (doseq [lang (sort installed)]
    (println (str \"  - \" lang))))
(println)
(println \"=== Support Matrix ===\")
(println)
(pp/pprint (audit/support-matrix))
"
}

# Scaffold language models or tests
cmd_scaffold() {
    local lang="\${1:-}"
    local type="\${2:-model}"
    
    if [[ -z "\$lang" ]]; then
        log_error "Language must be specified"
        log_info "Usage: \$0 scaffold <lang> [model|test|both]"
        exit 1
    fi
    
    log_info "Scaffolding \$type files for language: \$lang"
    run_clojure "
(require '[std.lang.manage.xtalk-scaffold :as scaffold])
(let [result (scaffold/scaffold-language (keyword (clojure.string/lower-case \"\$lang\"))
                                        {:write false
                                         :type (keyword (clojure.string/lower-case \"\$type\"))})]
  (if result
    (println \"Scaffold preview generated. Use :write true to persist.\")
    (println \"Failed to generate scaffold.\")))
"
}

# Show help
show_help() {
    cat << 'EOF'


                    XTalk Language Management CLI                            ║
                                                                             ║
 This tool provides management capabilities for XTalk language              ║
 specifications, model inventories, test coverage, and runtime configs.     ║

USAGE:
  ./bin/lang [COMMAND] [options]

COMMANDS:

  inventory [OPTIONS]
    Display model and test inventory across all XTalk languages
    Shows what language specifications are available in the codebase

  audit [OPTIONS]
    Audit installed languages and support matrix
    Checks which runtime languages are supported and available

  scaffold [LANG] [TYPE]
    Generate scaffolding for language models and tests
    Arguments:
      LANG    Language identifier (e.g., python, javascript, go)
      TYPE    model | test | both (default: model)

  help
    Show this help message

OPTIONS:
  --format FORMAT    Output format (text, json, edn)
  --verbose, -v      Enable verbose output
  --debug           Enable debug output

EXAMPLES:

  # Show XTalk inventory
  ./bin/lang inventory

  # Audit support matrix
  ./bin/lang audit

  # Scaffold Python model files
  ./bin/lang scaffold python model

  # Scaffold both model and test files
  ./bin/lang scaffold go both

ENVIRONMENT:
  PROJECT_ROOT       Set custom project root (auto-detected by default)
  LANG_DEBUG         Set to 1 to enable debug logging

RELATED:
  For more information, see MANAGE_XTALK.md in the project root.
  Documentation: https://github.com/zcaudate-xyz/foundation-base

EOF
}

# Main entry point
main() {
    local cmd="\${1:-inventory}"
    
    case "\$cmd" in
        inventory)
            cmd_inventory
            ;;
        audit)
            cmd_audit
            ;;
        scaffold)
            cmd_scaffold "\${2:-}" "\${3:-model}"
            ;;
        help|-h|--help)
            show_help
            ;;
        *)
            log_error "Unknown command: \$cmd"
            show_help
            exit 1
            ;;
    esac
}

# Run main if invoked as script
if [[ "\${BASH_SOURCE[0]}" == "\${0}" ]]; then
    check_lein
    main "$@"
fi
